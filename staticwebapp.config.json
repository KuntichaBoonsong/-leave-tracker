{
  "routes": [
    {
      "route": "/employee/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/manager/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/admin/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "responseOverrides": {
    "401": {
      "redirect": "/index.html"
    }
  }
}
